# Host-local scratch: one-off probes, dataset caches, result JSONs,
# anything that shouldn't leave this machine. Drop any new local file
# into sandbox/ rather than adding another entry here.
sandbox/

# Directory-level ignores only — no individual files below.
/results/
/runs/
__pycache__/
.ruff_cache/
*.pyc

# Per-run logs from the recurrence-analysis pipeline.
trace_analysis/results/logs/

# Splice-candidate manifests are derived from the parquet + a min-match
# threshold — regenerated by categorize_matches.py, kept locally as
# pipeline scratch but not versioned.
trace_analysis/results/*.splice_candidates.jsonl
